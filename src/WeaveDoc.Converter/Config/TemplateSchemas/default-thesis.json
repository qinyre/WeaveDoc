{
  "$schema": "https://weavedoc.dev/schemas/afd-template-v1.json",
  "meta": {
    "templateName": "默认学术论文",
    "version": "1.0.0",
    "author": "WeaveDoc",
    "description": "默认学术论文学位论文模板"
  },
  "defaults": {
    "fontFamily": "宋体",
    "fontSize": 12,
    "lineSpacing": 1.5,
    "pageSize": { "width": 210, "height": 297 },
    "margins": { "top": 25, "bottom": 25, "left": 30, "right": 30 }
  },
  "styles": {
    "heading1": {
      "displayName": "标题 1",
      "fontFamily": "黑体",
      "fontSize": 16,
      "bold": true,
      "alignment": "center",
      "spaceBefore": 24,
      "spaceAfter": 18,
      "lineSpacing": 1.5
    },
    "heading2": {
      "displayName": "标题 2",
      "fontFamily": "黑体",
      "fontSize": 14,
      "bold": true,
      "alignment": "left",
      "spaceBefore": 18,
      "spaceAfter": 12,
      "lineSpacing": 1.5
    },
    "heading3": {
      "displayName": "标题 3",
      "fontFamily": "黑体",
      "fontSize": 13,
      "bold": true,
      "alignment": "left",
      "spaceBefore": 12,
      "spaceAfter": 6,
      "lineSpacing": 1.5
    },
    "heading4": {
      "displayName": "标题 4",
      "fontFamily": "黑体",
      "fontSize": 12,
      "bold": true,
      "alignment": "left",
      "spaceBefore": 12,
      "spaceAfter": 6,
      "lineSpacing": 1.5
    },
    "heading5": {
      "displayName": "标题 5",
      "fontFamily": "黑体",
      "fontSize": 12,
      "bold": true,
      "italic": true,
      "alignment": "left",
      "spaceBefore": 6,
      "spaceAfter": 3,
      "lineSpacing": 1.5
    },
    "heading6": {
      "displayName": "标题 6",
      "fontFamily": "黑体",
      "fontSize": 12,
      "italic": true,
      "alignment": "left",
      "spaceBefore": 6,
      "spaceAfter": 3,
      "lineSpacing": 1.5
    },
    "body": {
      "displayName": "正文",
      "fontFamily": "宋体",
      "fontSize": 12,
      "firstLineIndent": 24,
      "lineSpacing": 1.5
    },
    "blockquote": {
      "displayName": "引用块",
      "fontFamily": "宋体",
      "fontSize": 12,
      "lineSpacing": 1.5
    },
    "list": {
      "displayName": "列表段落",
      "fontFamily": "宋体",
      "fontSize": 12,
      "lineSpacing": 1.5
    },
    "codeblock": {
      "displayName": "代码块",
      "fontFamily": "Consolas",
      "fontSize": 10,
      "lineSpacing": 1.0
    }
  },
  "headerFooter": {
    "header": {
      "text": "学位论文",
      "fontFamily": "宋体",
      "fontSize": 10.5,
      "alignment": "center"
    },
    "footer": {
      "pageNumbering": true,
      "format": "arabic",
      "alignment": "center",
      "startPage": 1
    }
  }
}
